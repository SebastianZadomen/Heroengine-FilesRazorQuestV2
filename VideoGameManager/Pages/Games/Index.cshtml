@page
@model VideoGameManager.Pages.Games.IndexModel
@{
    ViewData["Title"] = "Home page";
}

<div class="text-center">
    <h1 class="display-4">Lista de juegos</h1>

    <table class="table table-bordered table-dark">
        <thead>
            <tr>
                <th>Id</th>
                <th>Title</th>
                <th>Genre</th>
                <th>Year</th>
                <th>Score</th>
                <th>Description</th>
            </tr>
        </thead>
         <tbody>
            @foreach (var game in Model.Games)
            {
                <tr>
                    <td>@game.Id</td>
                    <td>@game.Title</td>
                    <td>@game.Genre</td>
                    <td>@game.Year</td>
                    <td>@game.Score</td>
                    <td>@game.Description</td>
                    <td><a class="btn btn-info" asp-page="./Details" asp-route-id="@game.Id">Detalles</a></td>
                    <td><a class="bg-body">Edit</a></td>
                    <td>
                        <form method="post" asp-page-handler="Delete" asp-route-id="@game.Id">
                            <button type="submit" class="btn btn-danger">Eliminar</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
